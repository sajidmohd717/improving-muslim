rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.email in [
          'sajidmohammad460519@gmail.com'
        ];
    }

    function optionalSyncFieldsAreSafe() {
      return (!('progress' in request.resource.data) || request.resource.data.progress is map)
        && (!('notes' in request.resource.data) || request.resource.data.notes is map)
        && (!('saved' in request.resource.data) || request.resource.data.saved is list)
        && (!('savedItems' in request.resource.data) || request.resource.data.savedItems is map)
        && (!('streak' in request.resource.data) || request.resource.data.streak is map)
        && (!('lastSyncedAt' in request.resource.data) || request.resource.data.lastSyncedAt is int);
    }

    function safeSyncDocument() {
      return request.resource.data.keys().hasOnly([
        'progress',
        'notes',
        'saved',
        'savedItems',
        'streak',
        'lastSyncedAt'
      ]) && optionalSyncFieldsAreSafe();
    }

    function safeLeaderboardDocument() {
      return request.resource.data.keys().hasOnly([
        'displayName',
        'current',
        'best',
        'targetMinutes',
        'lastCompletedDate',
        'activeThrough',
        'updatedAt'
      ])
      && request.resource.data.keys().hasAll([
        'displayName',
        'current',
        'best',
        'targetMinutes',
        'lastCompletedDate',
        'updatedAt'
      ])
      && request.resource.data.displayName is string
      && request.resource.data.displayName.matches('^[^@<>]{1,60}$')
      && request.resource.data.current is int
      && request.resource.data.current >= 0
      && request.resource.data.current <= 5000
      && request.resource.data.best is int
      && request.resource.data.best >= request.resource.data.current
      && request.resource.data.best <= 5000
      && request.resource.data.targetMinutes == 15
      && request.resource.data.lastCompletedDate is string
      && request.resource.data.lastCompletedDate.matches('^$|^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
      && (!('activeThrough' in request.resource.data)
        || (request.resource.data.activeThrough is string
          && request.resource.data.activeThrough.matches('^$|^[0-9]{4}-[0-9]{2}-[0-9]{2}$')))
      && request.resource.data.updatedAt is int
      && request.resource.data.updatedAt > 0;
    }

    function safeSearchEvent() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'query',
          'queryLower',
          'resultCount',
          'contentType',
          'category',
          'userId',
          'createdAt',
          'createdAtMs'
        ])
        && request.resource.data.keys().hasAll([
          'query',
          'queryLower',
          'resultCount',
          'contentType',
          'category',
          'userId',
          'createdAt',
          'createdAtMs'
        ])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.query is string
        && request.resource.data.query.size() > 0
        && request.resource.data.query.size() <= 160
        && request.resource.data.queryLower is string
        && request.resource.data.queryLower.size() > 0
        && request.resource.data.queryLower.size() <= 160
        && request.resource.data.resultCount is int
        && request.resource.data.resultCount >= 0
        && request.resource.data.resultCount <= 10000
        && request.resource.data.contentType is string
        && request.resource.data.contentType.matches('^(all|series|videos)$')
        && request.resource.data.category is string
        && request.resource.data.category.size() > 0
        && request.resource.data.category.size() <= 60
        && request.resource.data.createdAt is timestamp
        && request.resource.data.createdAtMs is int
        && request.resource.data.createdAtMs > 0;
    }

    match /users/{userId}/data/{documentId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId)
        && documentId == 'sync'
        && safeSyncDocument();
      allow delete: if isOwner(userId);
    }

    match /leaderboard/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && safeLeaderboardDocument();
      allow delete: if isOwner(userId);
    }

    match /searchEvents/{eventId} {
      allow create: if safeSearchEvent();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
